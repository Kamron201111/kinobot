# ═══════════════════════════════════════════════════════════════════
#  KINO BOT — Environment variables
#  Railway'da "Variables" bo'limiga shularni qo'shing
# ═══════════════════════════════════════════════════════════════════

# Bot tokeni (@BotFather'dan oling) — MAJBURIY
BOT_TOKEN=8474769024:AAGIBGwIRRGR8rdF67AUpTD_TUyefGKyELU

# Asosiy admin(lar) Telegram ID'si — vergul bilan ajrating — MAJBURIY
# O'z ID'ingizni @userinfobot dan bilib oling
ADMIN_IDS=6498632307

# PostgreSQL ulanish — Railway PostgreSQL qo'shsangiz AVTOMATIK keladi
# Qo'lda kiritmang, Railway "Add PostgreSQL" tugmasi orqali ulang
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Premium (custom) emoji yoqilsinmi? 1=ha, 0=yo'q
# Premium emoji faqat bot egasi Telegram Premium bo'lsa ko'rinadi.
# 0 qilsangiz oddiy emoji ishlatiladi (lekin ranglar baribir ishlaydi).
PREMIUM_EMOJI=1

# ─── WEBHOOK (ixtiyoriy) ───────────────────────────────────────────
# Bo'sh qoldirsangiz bot POLLING rejimida ishlaydi (Railway uchun mos).
# Webhook kerak bo'lsa Railway public domeningizni kiriting:
# WEBHOOK_HOST=https://your-app.up.railway.app
# WEBHOOK_SECRET=maxfiy_kalit_12345
